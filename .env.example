# Port for the dashboard web server (default: 3000)
PORT=3000

# Optional: Binance API keys (not required for public WebSocket streams)
# BINANCE_API_KEY=
# BINANCE_API_SECRET=

# Trading mode: paper | live
TRADING_MODE=paper

# Per-trade stake in USDC
TRADE_SIZE_USDC=10

# Live mode safety: keep true for shadow mode (pipeline runs, order is not sent)
LIVE_DRY_RUN=true

# Real-money opt-in: required when LIVE_DRY_RUN=false. Bot refuses to start
# with live orders enabled unless this is explicitly set to true.
LIVE_TRADING_CONFIRMED=false

# Polymarket CLOB settings (required only for TRADING_MODE=live)
# POLY_CLOB_HOST=https://clob.polymarket.com
# POLY_CHAIN_ID=137
# POLY_PRIVATE_KEY=0x...
# POLY_SIGNATURE_TYPE=1
# POLY_FUNDER_ADDRESS=0x...
# POLY_EXPECTED_SIGNER_ADDRESS=0x...   # required for live: must equal wallet derived from POLY_PRIVATE_KEY

# Optional live order guards
# LIVE_MAX_BUY_PRICE_IMPACT=0.03
# LIVE_MIN_ORDER_BUFFER_PCT=0.05

# Risk guards (apply in both paper and live)
MAX_OPEN_POSITIONS=1
MAX_DAILY_LOSS_USDC=5
MAX_CONSECUTIVE_LOSSES=4
MAX_CONSECUTIVE_TICK_ERRORS=5

# Live bankroll & dynamic sizing (only used when TRADING_MODE=live)
# INITIAL_BANKROLL_USDC: starting capital — drawdown is measured against this
INITIAL_BANKROLL_USDC=100
# MAX_DRAWDOWN_PCT: fraction (0.20 = 20%); bot hard-exits when breached
MAX_DRAWDOWN_PCT=0.20
# BASE_POSITION_PCT: baseline fraction of bankroll staked (scaled by half-Kelly)
BASE_POSITION_PCT=0.02
# MIN_POSITION_USDC / MAX_POSITION_USDC: clamp for computed size
MIN_POSITION_USDC=5
MAX_POSITION_USDC=25
# LOSS_DAMP_FACTOR: size reduction per consecutive loss (floor 20%)
LOSS_DAMP_FACTOR=0.25

# Predictor thresholds
# Global minimum confidence threshold (default 0.65)
ML_CONF_THRESHOLD=0.65
# Optional override used only when TRADING_MODE=live and LIVE_DRY_RUN=true
# ML_CONF_THRESHOLD_DRY_RUN=0.58
# Optional separate UP threshold (fallback: ML_CONF_THRESHOLD or dry-run override)
# ML_CONF_THRESHOLD_UP=0.65
# Max confidence cap (default 0.85)
# ML_CONF_MAX=0.85
