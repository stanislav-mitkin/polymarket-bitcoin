{
  "name": "polymarket-demo-bot",
  "version": "1.0.0",
  "description": "Polymarket BTC 5-Minute paper trading bot with dashboard",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/main.ts",
    "build": "tsc && cp -r src/dashboard/public dist/dashboard/public",
    "start": "node --env-file=.env dist/main.js",
    "dashboard": "tsx --env-file=.env src/dashboard/server.ts",
    "report": "node --env-file=.env dist/scripts/regime-report.js",
    "report:dev": "tsx --env-file=.env src/scripts/regime-report.ts",
    "preflight:live": "node --env-file=.env dist/scripts/live-preflight.js",
    "preflight:live:dev": "tsx --env-file=.env src/scripts/live-preflight.ts",
    "audit:live": "node --env-file=.env dist/scripts/live-reconciliation-audit.js",
    "audit:live:dev": "tsx --env-file=.env src/scripts/live-reconciliation-audit.ts"
  },
  "dependencies": {
    "@polymarket/clob-client": "^5.8.1",
    "better-sqlite3": "^9.4.3",
    "binance": "^2.8.0",
    "express": "^4.18.2",
    "ethers": "^6.11.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
